# Public site URL used for canonical/sitemap/OG metadata
# Replace with your custom domain in production when decided
NEXT_PUBLIC_SITE_URL=https://konkatsu-yoji-hensachi.vercel.app
# Backward-compatible alias used by some helpers
NEXT_PUBLIC_URL=

# Google Analytics 4 Measurement ID (optional)
# Set this in production to enable page_view and custom event tracking
# e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# X profile URL
NEXT_PUBLIC_X_URL=https://x.com/yauyuism

# note profile URL (optional)
NEXT_PUBLIC_NOTE_URL=https://note.com/yauyuism

# Anthropic API key for /api/analyze and /api/read-filter
ANTHROPIC_API_KEY=

# Optional HMAC secret for staged analysis token signing
ANALYZE_TOKEN_SECRET=

# Optional global safety valve for daily analysis requests
MAX_DAILY_REQUESTS=

# Optional Upstash/Vercel KV for rate limit + anonymous stats
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Optional retention for anonymous stat raw records saved in KV list
# Set 0 to disable raw record storage
STATS_RECORD_RETENTION=500

# Optional retention for anonymous condition-check snapshots saved in KV list
# Set 0 to disable raw record storage
CONDITIONS_STATS_RECORD_RETENTION=3000

# Optional retention for anonymous market-equivalent snapshots saved in KV list
# Set 0 to disable raw record storage
MARKET_STATS_RECORD_RETENTION=3000

# Optional retention for anonymous My 9 Specs snapshots saved in KV list
# Set 0 to disable raw record storage
MY9SPECS_STATS_RECORD_RETENTION=3000
